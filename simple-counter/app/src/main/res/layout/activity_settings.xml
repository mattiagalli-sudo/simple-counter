<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="PIN"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/currentPinInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Current PIN"
            android:inputType="numberPassword"
            android:maxLength="12" />

        <EditText
            android:id="@+id/newPinInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New PIN"
            android:inputType="numberPassword"
            android:maxLength="12" />

        <EditText
            android:id="@+id/confirmPinInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm new PIN"
            android:inputType="numberPassword"
            android:maxLength="12" />

        <Button
            android:id="@+id/savePinButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save PIN" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Display text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/counterPrefixInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Text before main counter"
            android:inputType="text" />

        <EditText
            android:id="@+id/counterLabelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Text after main counter, e.g. reps"
            android:inputType="text" />

        <EditText
            android:id="@+id/derivedPrefixInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Text before secondary values"
            android:inputType="text" />

        <EditText
            android:id="@+id/derivedLabelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Text after secondary values, e.g. points"
            android:inputType="text" />

        <Button
            android:id="@+id/saveDisplayTextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Secondary operations"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/operationsListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No operations configured" />

        <EditText
            android:id="@+id/operationLabelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Operation label, e.g. Score"
            android:inputType="text" />

        <Spinner
            android:id="@+id/operationTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/multiplierInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Operation number"
            android:inputType="numberDecimal|numberSigned" />

        <Button
            android:id="@+id/saveMultiplierButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add operation" />

        <Button
            android:id="@+id/clearOperationsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear operations" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Date and time"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/dateFormatSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Spinner
            android:id="@+id/updateIntervalSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Text color"
            android:textSize="18sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/textColorPicker"
            layout="@layout/view_color_picker" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Background color"
            android:textSize="18sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/backgroundColorPicker"
            layout="@layout/view_color_picker" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Font"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/fontStyleSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <SeekBar
            android:id="@+id/fontSizeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="128" />

        <TextView
            android:id="@+id/fontSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Counter font size: 72sp" />

        <SeekBar
            android:id="@+id/clockSizeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="32" />

        <TextView
            android:id="@+id/clockSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clock font size: 16sp" />

        <Button
            android:id="@+id/doneButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Done" />
    </LinearLayout>
</ScrollView>
